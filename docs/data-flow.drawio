<mxfile host="app.diagrams.net" type="device">
  <diagram id="data-flow" name="Data Flow &amp; Partitions">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="MessageNotify — 数据走向与分区对应 (Kafka → Dispatcher → Telegram / Teams)" style="text;html=1;align=left;verticalAlign=middle;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="900" height="30" as="geometry" />
        </mxCell>

        <!-- ============ Producers ============ -->
        <mxCell id="prodTitle" value="生产端服务 (各微服务)\nproduce 时用 service 作为 message key" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="190" height="34" as="geometry" />
        </mxCell>
        <mxCell id="p1" value="order-service" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="50" y="120" width="170" height="44" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="payment-service" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="50" y="200" width="170" height="44" as="geometry" />
        </mxCell>
        <mxCell id="p3" value="user-service" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="50" y="280" width="170" height="44" as="geometry" />
        </mxCell>

        <!-- ============ Kafka topic with partitions ============ -->
        <mxCell id="topic" value="Kafka topic: notifications" style="swimlane;html=1;startSize=28;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="90" width="230" height="270" as="geometry" />
        </mxCell>
        <mxCell id="part0" value="Partition 0\n(key hash → P0)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="topic">
          <mxGeometry x="20" y="40" width="190" height="60" as="geometry" />
        </mxCell>
        <mxCell id="part1" value="Partition 1\n(key hash → P1)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="topic">
          <mxGeometry x="20" y="110" width="190" height="60" as="geometry" />
        </mxCell>
        <mxCell id="part2" value="Partition 2\n(key hash → P2)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="topic">
          <mxGeometry x="20" y="180" width="190" height="60" as="geometry" />
        </mxCell>

        <!-- Producer -> partition edges (key decides partition; same key => same partition => 有序) -->
        <mxCell id="e1" style="endArrow=block;html=1;strokeColor=#6c8ebf;fontSize=10;" edge="1" parent="1" source="p1" target="part0">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e1l" value="key=order-service" style="text;html=1;fontSize=9;labelBackgroundColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="225" y="118" width="80" height="20" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="endArrow=block;html=1;strokeColor=#6c8ebf;fontSize=10;" edge="1" parent="1" source="p2" target="part1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2l" value="key=payment-service" style="text;html=1;fontSize=9;labelBackgroundColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="225" y="200" width="80" height="20" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="endArrow=block;html=1;strokeColor=#6c8ebf;fontSize=10;" edge="1" parent="1" source="p3" target="part2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3l" value="key=user-service" style="text;html=1;fontSize=9;labelBackgroundColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="225" y="280" width="80" height="20" as="geometry" />
        </mxCell>

        <!-- ============ Consumer group ============ -->
        <mxCell id="cg" value="Consumer group: message-notify\n(同组内：分区数 ≥ 实例数；一个分区只给一个实例消费)" style="swimlane;html=1;startSize=40;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="600" y="90" width="260" height="270" as="geometry" />
        </mxCell>
        <mxCell id="c1" value="实例 #1  ← Partition 0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="cg">
          <mxGeometry x="20" y="50" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="c2" value="实例 #2  ← Partition 1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="cg">
          <mxGeometry x="20" y="120" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="c3" value="实例 #3  ← Partition 2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="cg">
          <mxGeometry x="20" y="190" width="220" height="50" as="geometry" />
        </mxCell>

        <!-- partition -> instance edges -->
        <mxCell id="a0" style="endArrow=block;html=1;strokeColor=#d79b00;" edge="1" parent="1" source="part0" target="c1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a1" style="endArrow=block;html=1;strokeColor=#d79b00;" edge="1" parent="1" source="part1" target="c2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a2" style="endArrow=block;html=1;strokeColor=#d79b00;" edge="1" parent="1" source="part2" target="c3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============ Inside one instance: pipeline ============ -->
        <mxCell id="pipe" value="单个实例内部处理流程" style="swimlane;html=1;startSize=28;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="420" width="370" height="160" as="geometry" />
        </mxCell>
        <mxCell id="kc" value="NotificationConsumer\n@KafkaListener · 反序列化 JSON" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;" vertex="1" parent="pipe">
          <mxGeometry x="20" y="40" width="320" height="44" as="geometry" />
        </mxCell>
        <mxCell id="disp" value="NotificationDispatcher\n按 channel 路由 (telegram / teams / all) + 记录指标" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;" vertex="1" parent="pipe">
          <mxGeometry x="20" y="100" width="320" height="44" as="geometry" />
        </mxCell>

        <!-- consumer instance -> pipeline -->
        <mxCell id="topoll" value="poll records (NotificationMessage)" style="endArrow=block;html=1;strokeColor=#82b366;fontSize=9;dashed=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="c1" target="pipe">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="kc2disp" style="endArrow=block;html=1;strokeColor=#9673a6;" edge="1" parent="pipe" source="kc" target="disp">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============ Senders ============ -->
        <mxCell id="tg" value="TelegramNotificationSender\nresolveChatId(service)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="740" y="430" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="tm" value="TeamsNotificationSender\nresolveWebhookUrl(service)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="740" y="520" width="220" height="50" as="geometry" />
        </mxCell>

        <!-- dispatcher -> senders -->
        <mxCell id="d2tg" value="channel = telegram / all" style="endArrow=block;html=1;strokeColor=#6c8ebf;fontSize=9;" edge="1" parent="1" source="disp" target="tg">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="d2tm" value="channel = teams / all" style="endArrow=block;html=1;strokeColor=#6c8ebf;fontSize=9;" edge="1" parent="1" source="disp" target="tm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============ Destinations ============ -->
        <mxCell id="tgA" value="✈ Telegram 群 A (order)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="1060" y="380" width="200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="tgB" value="✈ Telegram 群 B (payment)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="1060" y="430" width="200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="tgD" value="✈ Telegram 默认群 (兜底)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="1060" y="480" width="200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="tmA" value="Teams 频道 A (order)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="1060" y="540" width="200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="tmB" value="Teams 频道 B (payment)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="1060" y="590" width="200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="tmD" value="Teams 默认频道 (兜底)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="1060" y="640" width="200" height="40" as="geometry" />
        </mxCell>

        <!-- sender -> destination edges (routed by service) -->
        <mxCell id="tg2a" value="service=order-service" style="endArrow=block;html=1;strokeColor=#82b366;fontSize=9;" edge="1" parent="1" source="tg" target="tgA">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="tg2b" value="service=payment-service" style="endArrow=block;html=1;strokeColor=#82b366;fontSize=9;" edge="1" parent="1" source="tg" target="tgB">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="tg2d" value="未匹配 → chat-id" style="endArrow=block;html=1;strokeColor=#999999;fontSize=9;dashed=1;" edge="1" parent="1" source="tg" target="tgD">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="tm2a" value="service=order-service" style="endArrow=block;html=1;strokeColor=#82b366;fontSize=9;" edge="1" parent="1" source="tm" target="tmA">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="tm2b" value="service=payment-service" style="endArrow=block;html=1;strokeColor=#82b366;fontSize=9;" edge="1" parent="1" source="tm" target="tmB">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="tm2d" value="未匹配 → webhook-url" style="endArrow=block;html=1;strokeColor=#999999;fontSize=9;dashed=1;" edge="1" parent="1" source="tm" target="tmD">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============ Observability ============ -->
        <mxCell id="metrics" value="Actuator + Micrometer\nPrometheus /actuator/prometheus  ·  端口 8088" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="300" y="640" width="330" height="50" as="geometry" />
        </mxCell>
        <mxCell id="disp2m" value="notify_messages_sent / skipped / dropped" style="endArrow=block;html=1;strokeColor=#b85450;fontSize=9;dashed=1;" edge="1" parent="1" source="disp" target="metrics">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="api" value="REST API  POST /api/notifications  ·  端口 8080\n(手动触发，与 Kafka 同一条 Dispatcher 路径)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="300" y="710" width="330" height="50" as="geometry" />
        </mxCell>
        <mxCell id="api2disp" style="endArrow=block;html=1;strokeColor=#d6b656;dashed=1;" edge="1" parent="1" source="api" target="pipe">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Notes -->
        <mxCell id="note1" value="要点：\n• 多个生产者写同一 topic 无需为此建分区；分区数决定并行消费与有序粒度。\n• 同一 service 用同一 key → 落到同一分区 → 该服务内部有序。\n• 分区数 ≥ 消费实例数；多出的实例会空闲。\n• channel 决定走哪个渠道，service 决定渠道内发往哪个群/频道。" style="text;html=1;align=left;verticalAlign=top;fontSize=10;fillColor=#ffffff;strokeColor=#cccccc;rounded=1;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="700" y="640" width="540" height="120" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
